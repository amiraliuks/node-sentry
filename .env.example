MQTT_BROKER=localhost
MQTT_PORT=1883

# Signs the session cookie. Generate a random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Protects the REST API. The server refuses to start with this unset unless
# NODESENTRY_DEV_MODE=1 (which binds to localhost only). Generate one the same way.
API_KEY=
